<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_above="@+id/main_banner_container"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="HuiiAd SDK Demo"
                android:textSize="24sp"
                android:textStyle="bold"
                android:layout_gravity="center_horizontal"
                android:layout_marginBottom="16dp"/>

            <Button
                android:id="@+id/btn_init"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Initialize SDK (Manual)" />

            <Button
                android:id="@+id/btn_init_manifest"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Initialize SDK (Manifest)" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#CCCCCC"
                android:layout_marginVertical="16dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Ad Formats"
                android:textSize="18sp"
                android:textStyle="bold"
                android:layout_marginBottom="8dp"/>

            <Button
                android:id="@+id/btn_banner_activity"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Open Banner Activity"
                android:backgroundTint="#FF6200EE"
                android:textColor="#FFFFFF" />

            <Button
                android:id="@+id/btn_native_activity"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Open Native Activity"
                android:backgroundTint="#FF018786"
                android:textColor="#FFFFFF" />

            <Button
                android:id="@+id/btn_video_activity"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Open Video Activity"
                android:backgroundTint="#FFB00020"
                android:textColor="#FFFFFF" />

            <Button
                android:id="@+id/btn_compose_activity"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Open Compose Activity"
                android:backgroundTint="#FF03DAC5"
                android:textColor="#000000" />

            <TextView
                android:id="@+id/tv_log"
                android:layout_width="match_parent"
                android:layout_height="150dp"
                android:layout_marginTop="16dp"
                android:background="#EEEEEE"
                android:padding="8dp"
                android:textSize="12sp"
                android:scrollbars="vertical"
                android:text="Logs will appear here..." />

        </LinearLayout>
    </ScrollView>

    <!-- Bottom Banner Container -->
    <FrameLayout
        android:id="@+id/main_banner_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:background="#F0F0F0"
        android:minHeight="50dp">
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Main Banner Ad Area"
            android:layout_gravity="center"
            android:textSize="12sp"
            android:textColor="#999"/>
    </FrameLayout>

</RelativeLayout>